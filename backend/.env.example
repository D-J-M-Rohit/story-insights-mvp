LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/story_insights
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
AUTH_COOKIE_ENABLED=true
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_MAX_AGE_MINUTES=10080
AUTH_RETURN_TOKEN_IN_BODY=false
AUTH_ALLOW_TOKEN_RESPONSE_OVERRIDE=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REPORT_LLM_SUMMARY_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_SALT=change-me-for-user-hashing
METRICS_ENABLED=true
PROVIDER_HEALTH_WINDOW=50
SLOW_SCENE_GENERATION_MS=3000
FEEDBACK_ENABLED=true
FEEDBACK_COMMENT_MAX_CHARS=300
ANALYSIS_NLP_ENABLED=true
ANALYSIS_SENTIMENT_ENABLED=true
ANALYSIS_TOPIC_TAGS_ENABLED=true
ANALYSIS_PII_REDACTION_ENABLED=true
ANALYSIS_COMMENT_MAX_CHARS=300
FEEDBACK_RAW_RETENTION_DAYS=90
FEEDBACK_AGGREGATE_RETENTION_DAYS=365
FEEDBACK_MICRO_PROMPT_ENABLED=true
FEEDBACK_MICRO_PROMPT_TURN=2
FEEDBACK_STYLE_HINT_TTL_TURNS=2
RETRIEVAL_ENABLED=false
RETRIEVAL_BACKEND=none
# allowed: none | exact | faiss_hnsw

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_REVISION=
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=64
EMBEDDING_NORMALIZE=true
EMBEDDING_CACHE_DIR=./.cache/sentence-transformers

FAISS_INDEX_DIR=./data/faiss
FAISS_INDEX_NAME=default
FAISS_HNSW_M=32
FAISS_EF_CONSTRUCTION=200
FAISS_EF_SEARCH=64
RETRIEVAL_TOP_K=10
RETRIEVAL_OVERFETCH_K=50

OBJECT_ARCHIVE_ENABLED=false
OBJECT_STORAGE_BACKEND=filesystem
# allowed: filesystem | s3 | minio
OBJECT_STORAGE_BUCKET=story-insights
OBJECT_STORAGE_PREFIX=story-insights
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_SIGNED_URL_TTL_SEC=300
OBJECT_STORAGE_FILESYSTEM_ROOT=./data/archive

ARCHIVE_RAW_TRACES_ENABLED=true
ARCHIVE_PROMPTS_ENABLED=true
ARCHIVE_PDFS_ENABLED=false
ARCHIVE_FAISS_SNAPSHOT_RETENTION_DAYS=14
ARCHIVE_TRACE_RETENTION_DAYS=30
ARCHIVE_PROMPT_RETENTION_DAYS=30
ARCHIVE_PDF_RETENTION_DAYS=7

BENCHMARK_DEBUG_FIELDS_ENABLED=true
SECURITY_HEADERS_ENABLED=true
CSP_CONNECT_SRC=http://localhost:8000 http://localhost:5173
PROVIDER_CIRCUIT_BREAKER_ENABLED=true
PROVIDER_CIRCUIT_FAILURE_THRESHOLD=5
PROVIDER_CIRCUIT_FAILURE_WINDOW_SEC=30
PROVIDER_CIRCUIT_OPEN_SEC=60
PROVIDER_CIRCUIT_HALF_OPEN_MAX_CALLS=1
BENCHMARK_COMPARISONS_ENABLED=true

# Backend PDF: playwright (HTML/CSS via Chromium) or reportlab (plain fallback).
# After pip install: python -m playwright install chromium
PDF_RENDERER=playwright
PDF_FALLBACK_REPORTLAB=true
PDF_INCLUDE_DEBUG=false
PDF_PAGE_SIZE=A4
PDF_MARGIN_TOP=14mm
PDF_MARGIN_RIGHT=12mm
PDF_MARGIN_BOTTOM=14mm
PDF_MARGIN_LEFT=12mm
