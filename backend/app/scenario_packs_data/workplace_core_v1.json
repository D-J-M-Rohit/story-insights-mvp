    { "id": "frag_workplace_cross_team_blocker", "content_type": "narrative_anchor", "tags": ["social", "communication", "priority"], "difficulty_min": 0.25, "difficulty_max": 0.70, "text": "A dependency team misses a handoff and your timeline is affected." },
    { "id": "frag_workplace_customer_hot_issue", "content_type": "narrative_anchor", "tags": ["risk", "stakeholder", "urgency"], "difficulty_min": 0.40, "difficulty_max": 0.90, "text": "A key customer reports a production issue during a launch window." },

    { "id": "anchor_workplace_risk", "content_type": "construct_anchor", "tags": ["risk", "tradeoff", "consequence"], "difficulty_min": 0.20, "difficulty_max": 0.90, "text": "Risk-focused scenes should contrast conservative, balanced, and bold choices with plausible outcomes." },
