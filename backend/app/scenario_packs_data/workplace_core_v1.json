  "fragments": [
    { "id": "frag_workplace_deadline_escalation", "content_type": "narrative_anchor", "tags": ["decisiveness", "social", "deadline", "stakeholder"], "difficulty_min": 0.30, "difficulty_max": 0.75, "text": "A stakeholder escalates a delivery concern shortly before a review." },
