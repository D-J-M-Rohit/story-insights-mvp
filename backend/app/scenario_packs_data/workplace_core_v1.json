    { "id": "anchor_workplace_empathy", "content_type": "construct_anchor", "tags": ["empathy", "impact", "perspective"], "difficulty_min": 0.20, "difficulty_max": 0.90, "text": "Empathy-focused scenes should include human impact signals without becoming therapeutic or clinical." },
    { "id": "anchor_workplace_decisiveness", "content_type": "construct_anchor", "tags": ["decisiveness", "deadline", "action"], "difficulty_min": 0.20, "difficulty_max": 0.90, "text": "Decisiveness scenes should reward timely direction while preserving realistic uncertainty." },
    { "id": "anchor_workplace_emotional_regulation", "content_type": "construct_anchor", "tags": ["emotional_regulation", "pressure", "tone"], "difficulty_min": 0.20, "difficulty_max": 0.90, "text": "Emotional-regulation scenes should create pressure without panic, diagnosis, insults, or extreme crisis." },

    { "id": "pattern_workplace_short_term_vs_long_term", "content_type": "consequence_pattern", "tags": ["risk", "consequence", "tradeoff"], "difficulty_min": 0.30, "difficulty_max": 0.85, "text": "Choices should balance immediate mitigation against longer-term delivery quality." },
    { "id": "pattern_workplace_alignment_cost", "content_type": "consequence_pattern", "tags": ["social", "coordination", "priority"], "difficulty_min": 0.25, "difficulty_max": 0.80, "text": "Choices should expose tension between broad alignment and fast execution." },

